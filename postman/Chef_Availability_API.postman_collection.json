{
    "info": {
        "_postman_id": "chef-availability-api",
        "name": "Chef Availability API",
        "description": "API لجلب بيانات توفر الطاهي مع ساعات الراحة الخاصة بكل خدمة والإجازات\n\nالتقويم يعمل بالمنطق التالي:\n- من التاريخ المرسل حتى نهاية الشهر\n- إذا كان المتبقي أقل من 10 أيام، يرجع للخلف لضمان 10 أيام على الأقل\n- يتضمن أيام الإجازات في calendar.vacation_days",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "base_url",
            "value": "https://monchef.codebrains.net"
        },
        {
            "key": "api_token",
            "value": ""
        }
    ],
    "item": [
        {
            "name": "Chef Availability",
            "item": [
                {
                    "name": "Get Chef Availability Calendar (Default)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            },
                            {
                                "key": "Content-Type",

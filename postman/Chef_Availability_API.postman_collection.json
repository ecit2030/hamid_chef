                                "value": "Bearer {{api_token}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/chefs/1/availability-calendar",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "chefs",
                                "1",
                                "availability-calendar"
                            ]
                        }
                    },
                    "response": [],
